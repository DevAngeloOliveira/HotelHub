# ===================================
# HotelHub Environment Variables
# Copy to .env.local and fill values
# ===================================

# ===== API CONFIG =====
# Base URL da API (client-side, usado no browser e mobile)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Base URL da API para SSR (server-side Node.js, apenas Next.js)
# Usado para requisições do servidor (não público no cliente)
API_INTERNAL_URL=http://localhost:8080/api/v1

# ===== NEXT.JS =====
NODE_ENV=development

# ===== MOBILE (EXPO) =====
# Token para testes (será substituído por login real em produção)
# EXPO_PUBLIC_ACCESS_TOKEN=seu_token_aqui

# ===== DATABASE (opcional, dev local) =====
# Para rodar API via ./gradlew bootRun em dev local
DATABASE_URL=postgresql://hotelhub:hotelhub@localhost:5432/hotelhub
REDIS_URL=redis://localhost:6379

# ===== DOCKER DEPLOYMENT =====
# Essas vars são usadas pelo docker-compose.yml
# Por padrão estão nos arquivos, mas você pode override:
# POSTGRES_USER=hotelhub
# POSTGRES_PASSWORD=hotelhub
# POSTGRES_DB=hotelhub
# REDIS_PORT=6379

# ===== API JWT (backend only) =====
# JWT_SECRET=sua_secret_key_aqui_min_32_chars
# JWT_EXPIRATION=3600

# ===== FEATURE FLAGS (opcional) =====
# NEXT_PUBLIC_ENABLE_ADMIN=true
# NEXT_PUBLIC_ENABLE_REVIEWS=true
