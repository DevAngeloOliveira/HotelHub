# ========================================
# HotelHub Environment Variables Template
# ========================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in ALL required variables (marked with [REQUIRED])
# 3. Never commit .env.local to git
# 4. For Docker, see docker-compose setup below
#
# ========================================

# ===== CLIENT CONFIGURATION (PUBLIC) =====
# Used in frontend (Next.js/React/Mobile)

# Public API Base URL (browser/mobile side)
# Local dev: http://localhost/api/v1 (via Nginx proxy)
# Docker: http://localhost/api/v1
# Production: https://api.hotelhub.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Internal API URL (server-side only, Next.js SSR)
# Used for server-to-server calls (not exposed to client)
# Docker: http://api:8080/api/v1
API_INTERNAL_URL=http://api:8080/api/v1

# ===== RUNTIME ENVIRONMENT =====
NODE_ENV=development

# ===== DATABASE CONFIGURATION [REQUIRED] =====
# PostgreSQL connection string
# Format: jdbc:postgresql://host:port/database
# Local: jdbc:postgresql://localhost:5432/hotelhub
# Docker: jdbc:postgresql://db:5432/hotelhub
DB_URL=jdbc:postgresql://localhost:5432/hotelhub

# PostgreSQL credentials [REQUIRED]
# In production, use strong credentials
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ===== REDIS CACHE [REQUIRED] =====
# Redis host and port for caching
# Local: localhost:6379
# Docker: redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2s

# Cache time-to-live
CACHE_TTL=300s

# ===== JWT AUTHENTICATION [REQUIRED] =====
# Secret key for JWT token generation
# CRITICAL: Use a strong 256-bit random key in production
# Generate: openssl rand -base64 32
# Min 32 characters
JWT_SECRET=change-me-to-a-strong-256-bit-key-in-production

# JWT token expiration in minutes
JWT_EXPIRATION_MINUTES=60

# ===== ADMIN SEED (Optional) =====
# Create default admin user on application startup
# Disable in production or use secure credentials
ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@hotelhub.local
ADMIN_SEED_PASSWORD=ChangeMe123!SecurePassword
ADMIN_SEED_NAME=System Administrator
ADMIN_SEED_PHONE=+55-11-99999-9999

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ===== FEATURE FLAGS (Optional) =====
# NEXT_PUBLIC_ENABLE_ADMIN=true
# NEXT_PUBLIC_ENABLE_REVIEWS=false
